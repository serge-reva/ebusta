x-loki-logging: &loki-logging
  driver: loki
  options:
    loki-url: "http://localhost:3100/loki/api/v1/push"
    loki-retries: "5"
    loki-batch-size: "400"

services:
  loki:
    image: grafana/loki:latest
    command: -config.file=/etc/loki/local-config.yaml
    ports:
      - "3100:3100"
    volumes:
      - ./deploy/loki/loki-config.yml:/etc/loki/local-config.yaml:ro
      - loki-data:/loki
    healthcheck:
      test: ["CMD", "/usr/bin/loki", "-version"]
      interval: 10s
      timeout: 3s
      retries: 10
      start_period: 20s
    restart: unless-stopped

  grafana:
    image: grafana/grafana:latest
    ports:
      - "3300:3000"
    volumes:
      - ./deploy/grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro
      - grafana-data:/var/lib/grafana
    depends_on:
      loki:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "/bin/sh", "-c", "test -d /usr/share/grafana"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 15s
    restart: unless-stopped
    logging: *loki-logging

  trace-viewer:
    image: "{{ docker_registry }}/ebusta-trace-viewer:{{ image_tag }}"
    ports:
      - "8089:8080"
    depends_on:
      loki:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8080/health"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 10s
    restart: unless-stopped
    logging: *loki-logging

  datamanager:
    image: "{{ docker_registry }}/ebusta-datamanager:{{ image_tag }}"
    ports:
      - "50051:50051"
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50051"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  dsl-scala:
    image: "{{ docker_registry }}/ebusta-dsl-scala:{{ image_tag }}"
    ports:
      - "50052:50052"
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50052"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  query-builder:
    image: "{{ docker_registry }}/ebusta-query-builder:{{ image_tag }}"
    ports:
      - "50053:50053"
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50053"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  orchestrator:
    image: "{{ docker_registry }}/ebusta-orchestrator:{{ image_tag }}"
    ports:
      - "50054:50054"
    depends_on:
      datamanager:
        condition: service_healthy
      dsl-scala:
        condition: service_healthy
      query-builder:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50054"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  tier-node:
    image: "{{ docker_registry }}/ebusta-tier-node:{{ image_tag }}"
    ports:
      - "50111:50111"
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
      - /opt/ebusta:/opt/ebusta
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50111"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  plasma-node:
    image: "{{ docker_registry }}/ebusta-plasma-node:{{ image_tag }}"
    ports:
      - "50112:50112"
    depends_on:
      tier-node:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
      - /opt/ebusta:/opt/ebusta
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "/app/grpc_health_probe", "-addr=localhost:50112"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  downloader:
    image: "{{ docker_registry }}/ebusta-downloader:{{ image_tag }}"
    ports:
      - "50081:50081"
    depends_on:
      plasma-node:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:50081/health"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  gateway:
    image: "{{ docker_registry }}/ebusta-gateway:{{ image_tag }}"
    ports:
      - "8443:8443"
    depends_on:
      orchestrator:
        condition: service_healthy
      downloader:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8443/health"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  web-frontend:
    image: "{{ docker_registry }}/ebusta-web-frontend:{{ image_tag }}"
    ports:
      - "3000:3000"
    depends_on:
      gateway:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s
    restart: unless-stopped
    logging: *loki-logging

  telegram-bot:
    profiles: ["telegram"]
    image: "{{ docker_registry }}/ebusta-telegram-bot:{{ image_tag }}"
    depends_on:
      gateway:
        condition: service_healthy
    volumes:
      - ./ebusta.yaml:/app/ebusta.yaml:ro
    environment:
      - EBUSTA_CONFIG=/app/ebusta.yaml
    dns:
      - 192.168.1.11
    restart: unless-stopped
    logging: *loki-logging

volumes:
  grafana-data:
  loki-data:
